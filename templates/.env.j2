{{ ansible_managed | comment }}

APP_URL={{ pocket_id_url }}
ENCRYPTION_KEY={{ pocket_id_encryption_key }}
TRUST_PROXY={{ pocket_id_trust_proxy | lower }}
{% if pocket_id_trusted_platform %}
TRUSTED_PLATFORM={{ pocket_id_trusted_platform }}
{% endif %}
{% if pocket_id_maxmind_license_key %}
MAXMIND_LICENSE_KEY={{ pocket_id_maxmind_license_key }}
{% endif %}
{% if pocket_id_geolite_db_url %}
GEOLITE_DB_URL={{ pocket_id_geolite_db_url }}
{% endif %}
LOG_LEVEL={{ pocket_id_log_level }}
LOG_JSON={{ (pocket_id_log_format == "json") | lower }}
ANALYTICS_DISABLED=true
VERSION_CHECK_DISABLED={{ (not pocket_id_version_check) | lower }}
{% if pocket_id_metrics %}
METRICS_ENABLED=true
OTEL_METRICS_EXPORTER=prometheus
OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
OTEL_EXPORTER_PROMETHEUS_PORT=9464
{% endif %}
